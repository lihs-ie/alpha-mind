{
  "serviceId": "svc-feature-engineering",
  "version": "1.0.0",
  "role": "市場データから学習・推論用特徴量を生成し、バージョン管理して保存する。",
  "aiResponsibility": true,
  "runtime": {
    "platform": "Cloud Run Job",
    "language": "Python",
    "networkExposure": "private"
  },
  "interfaces": {
    "events": {
      "subscribe": [
        "market.collected"
      ],
      "publish": [
        "features.generated",
        "features.generation.failed"
      ]
    }
  },
  "dependencies": {
    "datastores": [
      "Cloud Storage:raw_market_data",
      "Cloud Storage:feature_store",
      "Firestore:idempotency_keys",
      "Firestore:audit_logs"
    ],
    "messaging": [
      "Pub/Sub"
    ]
  },
  "workflow": [
    "market.collected受信",
    "入力データ読込",
    "時点整合チェック",
    "特徴量計算",
    "featureVersion採番",
    "Cloud Storage保存",
    "features.generated発行"
  ],
  "dataModels": {
    "outputEvent": {
      "features.generated": {
        "required": [
          "payload.featureVersion",
          "payload.storagePath",
          "payload.targetDate"
        ]
      }
    }
  },
  "idempotency": {
    "enabled": true,
    "key": "eventId",
    "store": "Firestore:idempotency_keys"
  },
  "retryPolicy": {
    "maxAttempts": 3,
    "backoff": "exponential",
    "retryableErrors": [
      "storage_transient_error"
    ],
    "nonRetryableErrors": [
      "future_data_leak_detected",
      "invalid_input_schema"
    ]
  },
  "qualityGates": [
    "将来情報リークなし",
    "必須特徴量欠損率閾値以内"
  ],
  "slo": {
    "jobCompletionWithinMinutes": 15,
    "successRate": "99.0%"
  },
  "observability": {
    "metrics": [
      "feature_job_success_total",
      "feature_job_failure_total",
      "feature_generation_duration_ms"
    ],
    "logFields": [
      "traceId",
      "eventId",
      "featureVersion",
      "result"
    ]
  }
}
