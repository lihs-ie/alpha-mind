# .env.local
# ローカル開発環境の共通環境変数。
# 実際のAPIキーはここに記述せず、secrets/ ディレクトリ経由でマウントする。
# このファイルはバージョン管理対象（プレースホルダー値のみ）。

# ---------------------------------------------------------------------------
# GCP
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=alpha-mind-local
GCP_REGION=asia-northeast1

# ---------------------------------------------------------------------------
# アプリケーション共通
# ---------------------------------------------------------------------------
APP_ENV=local
FIRESTORE_DATABASE=(default)
PUBSUB_TOPIC_PREFIX=event-

# ---------------------------------------------------------------------------
# GCPエミュレータ接続先（Dockerネットワーク内部アドレス）
# ---------------------------------------------------------------------------
FIRESTORE_EMULATOR_HOST=firestore:8080
PUBSUB_EMULATOR_HOST=pubsub:8085
STORAGE_EMULATOR_HOST=gcs:4443

# ---------------------------------------------------------------------------
# 外部APIキー（ローカル開発用プレースホルダー）
# 実際の値が必要なテストは各サービスのREADMEを参照
# ---------------------------------------------------------------------------
JQUANTS_API_KEY=local-jquants-api-key-placeholder
ALPACA_API_KEY=local-alpaca-api-key-placeholder
ALPACA_API_SECRET=local-alpaca-api-secret-placeholder
BROKER_API_KEY=local-broker-api-key-placeholder
BROKER_API_SECRET=local-broker-api-secret-placeholder
X_API_BEARER_TOKEN=local-x-api-bearer-token-placeholder
YOUTUBE_API_KEY=local-youtube-api-key-placeholder
LLM_API_KEY=local-llm-api-key-placeholder
MLFLOW_TRACKING_TOKEN=local-mlflow-tracking-token-placeholder
OIDC_CLIENT_SECRET=local-oidc-client-secret-placeholder

# ---------------------------------------------------------------------------
# BFF 内部通信
# ---------------------------------------------------------------------------
RISK_GUARD_BASE_URL=http://risk-guard:8080
